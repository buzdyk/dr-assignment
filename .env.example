# Host + container port for the Nuxt app. Override to change both sides.
PORT=3455

# Postgres credentials for the `db` compose service. The app reaches it via
# compose DNS (`db:5432`); the service is not published to the host.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nextrade

# AI provider used by /api/chat. "claude" (default) needs ANTHROPIC_API_KEY;
# "robot" is a deterministic offline stub for demos and tests.
AI_PROVIDER=claude
ANTHROPIC_API_KEY=

# Connection string used by `npm test`. The test harness creates an isolated
# `test` schema inside this database (NEVER touches `public`), runs migrations
# + seeders against it, then wraps each test in a rolled-back transaction.
# Defaults to the same Postgres the dev container runs against.
DATABASE_URL_TEST=postgres://postgres:postgres@db:5432/nextrade
