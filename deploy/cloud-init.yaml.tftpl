#cloud-config
package_update: true
package_upgrade: true

packages:
  - ca-certificates
  - curl
  - ufw

write_files:
  - path: /opt/app/docker-compose.yml
    permissions: "0644"
    content: |
      ${indent(6, compose_content)}

  - path: /opt/app/Caddyfile
    permissions: "0644"
    content: |
      ${indent(6, caddyfile_content)}

  - path: /opt/app/.env
    permissions: "0600"
    content: |
      POSTGRES_USER=postgres
      POSTGRES_PASSWORD=${postgres_password}
      POSTGRES_DB=nextrade
      DATABASE_URL=postgres://postgres:${postgres_password}@db:5432/nextrade
      APP_IMAGE=${app_image}
      MIGRATE_IMAGE=${migrate_image}
      DOMAIN=${domain}
      BASIC_AUTH_USER='${basic_auth_user}'
      BASIC_AUTH_HASH='${basic_auth_hash}'
      ANTHROPIC_API_KEY='${anthropic_api_key}'

  - path: /opt/app/bootstrap.sh
    permissions: "0755"
    content: |
      #!/usr/bin/env bash
      set -euo pipefail
      cd /opt/app
      docker compose --profile oneoff pull
      docker compose run --rm migrate
      docker compose run --rm seed
      docker compose up -d

runcmd:
  # Install Docker + Compose plugin
  - install -m 0755 -d /etc/apt/keyrings
  - curl -fsSL https://download.docker.com/linux/ubuntu/gpg -o /etc/apt/keyrings/docker.asc
  - chmod a+r /etc/apt/keyrings/docker.asc
  - bash -c 'echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/ubuntu $(. /etc/os-release && echo $VERSION_CODENAME) stable" > /etc/apt/sources.list.d/docker.list'
  - apt-get update
  - apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin

  # Firewall — SSH + HTTP(S) only; Postgres is never exposed
  - ufw default deny incoming
  - ufw default allow outgoing
  - ufw allow 22/tcp
  - ufw allow 80/tcp
  - ufw allow 443/tcp
  - ufw --force enable

  # Pull images, run migrations + seeds, then bring the stack up
  - bash /opt/app/bootstrap.sh

final_message: "cloud-init finished after $UPTIME seconds"
